{
  "name": "@pylon/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/App.tsx src/main.tsx src/api src/components src/contexts src/pages/{Agents,AgentDetail,AgentNew,Approvals,Calendar,ContentPipeline,Costs,Dashboard,Memory,Models,Providers,Runs,Settings,Skills,TasksBoard,TeamStructure,Workflows}.tsx src/pages/ads/*.tsx",
    "typecheck": "tsc -b",
    "test": "vitest",
    "test:contract": "vitest --run src/api/__tests__/client.test.ts src/api/__tests__/contract.test.ts",
    "lint:all": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@tailwindcss/oxide-darwin-arm64": "^4.2.1",
    "lightningcss-darwin-arm64": "^1.32.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.46.1",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
